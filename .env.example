BOT_TOKEN=123456:AA...
BOT_USERNAME=my_sub_bot
CRYPTO_PAY_TOKEN=12345:AA...
CRYPTO_PAY_NETWORK=test
CRYPTO_PAY_WEBHOOK_URL=https://bot.example.com/cryptopay/webhook
TELEGRAM_WEBHOOK_URL=https://bot.example.com/tg/webhook
TELEGRAM_WEBHOOK_SECRET=change-me-to-random-32-bytes
CHAT_IDS=-1001111111111,-1002222222222,-1003333333333,-1004444444444
DATABASE_URL=postgresql://user:pass@localhost:5432/subbot
PORT=8080
LOG_LEVEL=INFO

# Telegram ID администратора (числовой). 0 = нет админа, все админ-команды silent no-op.
ADMIN_TELEGRAM_ID=0

# --- Платёжные провайдеры ---
# CSV-список активных. Допустимые: cryptobot, heleket
ENABLED_PROVIDERS=cryptobot

# Heleket (TRC-20 USDT) — заполнить только если "heleket" в ENABLED_PROVIDERS
HELEKET_MERCHANT_UUID=
HELEKET_API_KEY=
HELEKET_WEBHOOK_PATH=/heleket/webhook
HELEKET_WEBHOOK_URL=https://bot.example.com/heleket/webhook
